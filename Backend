DB_PATH = "simulator.db"

def init_db():
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    cursor.execute("""
        CREATE TABLE IF NOT EXISTS simulations (
            id          INTEGER PRIMARY KEY AUTOINCREMENT,
            decision    TEXT NOT NULL,
            category    TEXT,
            budget      REAL,
            duration    INTEGER,
            risk_level  TEXT,
            ai_result   TEXT,
            created_at  TEXT DEFAULT (datetime('now'))
        )
    """)
    conn.commit()
    conn.close()

